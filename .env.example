# ── LLM Configuration ──
LLM_PROVIDER=ollama
LLM_MODEL=glm-5:cloud
OLLAMA_API_KEY=your_ollama_cloud_api_key_here
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.3
LLM_MAX_RETRIES=3

# ── Feature Flags ──
ENABLE_LLM_REVIEW=true
REVIEW_CONFIDENCE_THRESHOLD=0.85

# ── App Settings ──
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*
